<!-- /templates/index.html -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mentor IA Académico</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; background-color: #f5f5f5; }
        h1 { color: #333; }
        .container { max-width: 800px; margin: auto; background: #fff; padding: 20px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        textarea { width: 100%; height: 120px; margin-bottom: 10px; }
        button { padding: 10px 20px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; }
        button:hover { background: #0056b3; }
        #resultado { margin-top: 20px; white-space: pre-wrap; background: #e9ecef; padding: 10px; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Mentor IA Académico</h1>
        <p>Introduce tu texto y elige la acción:</p>

        <textarea id="texto" placeholder="Escribe aquí tu texto o pega material de estudio..."></textarea>
        <br>

        <button onclick="analizar()">Analizar</button>
        <button onclick="resumen()">Resumen Académico</button>
        <button onclick="corregir()">Corregir</button>
        <button onclick="rap()">Rap Académico</button>
        <button onclick="mapa()">Mapa Conceptual</button>

        <div id="resultado"></div>
    </div>

    <script>
        async function enviar(endpoint, extra={}) {
            const texto = document.getElementById('texto').value;
            const body = { texto, ...extra };
            const res = await fetch(`/${endpoint}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            document.getElementById('resultado').innerText = data.resultado || JSON.stringify(data);
        }

        function analizar() { enviar('analizar'); }
        function resumen() { enviar('resumen'); }
        function corregir() { enviar('corregir', { respuesta: '' }); }
        function rap() { enviar('rap'); }
        function mapa() { enviar('mapa'); }
    </script>
</body>
</html>
